---
import { getCollection, render } from "astro:content";
import DocsLayout from "~/layouts/DocsLayout.astro";
import { docsOrder, findDoc } from "~/content/docs/_meta";

export async function getStaticPaths() {
  const all = await getCollection("docs");
  const entries = all.filter((e) => e.id.toLowerCase().startsWith("en/"));
  return entries.map((entry) => {
    const slug = entry.id.replace(/^en\//i, "").replace(/\.md$/, "");
    return {
      params: { slug },
      props: { entry, slug },
    };
  });
}

const { entry, slug } = Astro.props;
const meta = findDoc(slug);
const { Content, headings } = await render(entry);

const idx = docsOrder.findIndex((d) => d.slug === slug);
const prev = idx > 0 ? docsOrder[idx - 1] : undefined;
const next = idx >= 0 && idx < docsOrder.length - 1 ? docsOrder[idx + 1] : undefined;

const docLabel = meta?.label.en ?? slug;
const title = `${docLabel} · ThinkWatch Docs`;
const description = meta?.summary?.en;
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const jsonLd: Record<string, unknown>[] = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://thinkwat.ch/" },
      { "@type": "ListItem", position: 2, name: "Documentation", item: "https://thinkwat.ch/docs/" },
      { "@type": "ListItem", position: 3, name: docLabel, item: pageUrl },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    headline: docLabel,
    description,
    inLanguage: "en",
    url: pageUrl,
    author: { "@type": "Organization", name: "ThinkWatch Project", url: "https://github.com/ThinkWatchProject" },
    publisher: {
      "@type": "Organization",
      name: "ThinkWatch",
      logo: { "@type": "ImageObject", url: "https://thinkwat.ch/icon.svg" },
    },
  },
];
---

<DocsLayout
  title={title}
  description={description}
  current={slug}
  headings={headings}
  prev={prev}
  next={next}
  jsonLd={jsonLd}
>
  <Content />
</DocsLayout>
