---
const tiers = [
  {
    name: "Non-production",
    price: "Free",
    priceNote: "forever",
    highlight: false,
    audience: "Development, staging, evaluation, internal demos.",
    features: [
      "Unlimited tokens",
      "Unlimited MCP tool calls",
      "All gateway features",
      "All security features",
      "Community support",
    ],
    cta: { label: "Self-host now", href: "#quickstart" },
  },
  {
    name: "Production · Free Tier",
    price: "Free",
    priceNote: "up to thresholds",
    highlight: true,
    audience: "Small teams running production workloads.",
    features: [
      "Up to 10,000,000 billable tokens / month",
      "Up to 10,000 MCP tool calls / month",
      "All features included",
      "BSL 1.1 license",
      "Auto-converts to GPL-2.0-or-later after change date",
    ],
    cta: { label: "Read the license", href: "https://github.com/ThinkWatchProject/ThinkWatch/blob/main/LICENSING.md" },
  },
  {
    name: "Production · Commercial",
    price: "Tiered",
    priceNote: "by usage",
    highlight: false,
    audience: "Organizations exceeding the free thresholds.",
    features: [
      "Above 10M tokens or 10K MCP calls per UTC month",
      "Commercial license required",
      "Priced by usage tiers",
      "Priority support available",
      "Custom deployment guidance",
    ],
    cta: { label: "Contact us", href: "https://github.com/ThinkWatchProject/ThinkWatch/issues" },
  },
];
---

<section id="pricing" class="py-28 border-t border-white/5 relative">
  <div class="container-page relative z-10">
    <div class="max-w-3xl">
      <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-brand-1)] font-medium mb-4">
        License
      </div>
      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight">
        Source-available. <span class="text-gradient">Free for most teams</span>.
      </h2>
      <p class="mt-5 text-lg text-[var(--color-muted)] leading-relaxed">
        ThinkWatch is licensed under the Business Source License 1.1. Non-production use is free forever, and production use is free up to generous monthly thresholds — only commercial above that.
      </p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-3">
      {tiers.map((t) => (
        <div
          class:list={[
            "relative rounded-2xl border p-7 flex flex-col",
            t.highlight
              ? "border-transparent bg-[var(--color-surface)]/80 border-gradient"
              : "border-white/10 bg-[var(--color-surface)]/40",
          ]}
        >
          {t.highlight && (
            <div class="absolute -top-3 left-7 px-2.5 py-0.5 rounded-full text-[10px] uppercase tracking-wider font-semibold bg-brand-gradient text-black">
              Most teams
            </div>
          )}

          <div class="text-sm font-medium text-[var(--color-muted)]">{t.name}</div>
          <div class="mt-3 flex items-baseline gap-2">
            <span class="text-4xl font-semibold tracking-tight">{t.price}</span>
            <span class="text-xs text-[var(--color-dim)]">{t.priceNote}</span>
          </div>
          <p class="mt-3 text-sm text-[var(--color-muted)]">{t.audience}</p>

          <ul class="mt-6 space-y-2.5 text-sm flex-1">
            {t.features.map((f) => (
              <li class="flex gap-2.5 items-start">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-[var(--color-brand-1)]" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8.5L6.5 12L13 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-[var(--color-text)]">{f}</span>
              </li>
            ))}
          </ul>

          <a
            href={t.cta.href}
            class:list={[
              "mt-7 text-center text-sm font-medium px-4 py-2.5 rounded-lg transition",
              t.highlight
                ? "bg-brand-gradient text-black hover:brightness-110"
                : "border border-white/15 hover:border-white/30 hover:bg-white/5",
            ]}
          >
            {t.cta.label} →
          </a>
        </div>
      ))}
    </div>

    <p class="mt-10 text-center text-xs text-[var(--color-dim)]">
      "Billable Token" and "MCP Tool Call" definitions, the tiering model, and the changeover to GPL-2.0-or-later are all detailed in
      <a href="https://github.com/ThinkWatchProject/ThinkWatch/blob/main/LICENSING.md" class="text-white underline underline-offset-4 hover:text-[var(--color-brand-1)]">LICENSING.md</a>.
    </p>
  </div>
</section>
