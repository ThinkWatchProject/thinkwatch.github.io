---
import { getLang, t } from "~/i18n";

const s = t(getLang(Astro)).star;

const repo = "ThinkWatchProject/ThinkWatch";
const chartUrl = `https://api.star-history.com/svg?repos=${repo}&type=Date&theme=dark`;
const chartHref = `https://www.star-history.com/#${repo}&Date`;
---

<section class="py-24 border-t border-white/5">
  <div class="container-page">
    <div class="max-w-3xl mx-auto text-center">
      <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-brand-1)] font-medium mb-4">
        {s.eyebrow}
      </div>
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">
        {s.title}<span class="text-gradient">{s.titleHighlight}</span>.
      </h2>
      <p class="mt-4 text-[var(--color-muted)]">
        {s.sub}
      </p>
    </div>

    <a
      href={chartHref}
      target="_blank"
      rel="noopener"
      class="mt-12 block rounded-2xl border border-white/10 bg-[var(--color-surface)]/40 p-4 md:p-8 hover:border-white/20 transition-colors"
    >
      <img
        src={chartUrl}
        alt={`Star history chart for ${repo}`}
        loading="lazy"
        decoding="async"
        class="w-full h-auto rounded-lg"
      />
    </a>

    <div class="mt-8 text-center">
      <a
        href={`https://github.com/${repo}`}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-5 py-3 rounded-lg border border-white/15 hover:border-white/30 hover:bg-white/5 transition font-medium"
      >
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
        </svg>
        {s.cta}
      </a>
    </div>
  </div>
</section>
