---
import { getLang } from "~/i18n";

const lang = getLang(Astro);
const placeholder = lang === "zh-CN" ? "搜索文档…" : "Search docs…";
const buttonLabel = lang === "zh-CN" ? "搜索" : "Search";
const emptyHint = lang === "zh-CN" ? "开始输入以搜索文档。" : "Start typing to search the docs.";
const noResults = lang === "zh-CN" ? "未找到结果" : "No results";
---

<!--
  Pure-HTML, JS-on-demand search modal powered by Pagefind.
  - Trigger button lives in the header (rendered via the data attribute below).
  - The modal markup is a <dialog> hidden until first open.
  - Pagefind's runtime is loaded lazily the first time the user opens the modal.
-->

<button
  type="button"
  data-search-trigger
  aria-label={buttonLabel}
  class="flex items-center justify-center gap-2 text-xs text-[var(--color-muted)] hover:text-white border border-white/10 hover:border-white/25 rounded-md w-9 h-9 md:w-auto md:h-9 md:px-2.5 transition-colors"
>
  <svg class="w-4 h-4 md:w-3.5 md:h-3.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
    <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.4"/>
    <line x1="11" y1="11" x2="14" y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
  </svg>
  <span class="hidden md:inline">{buttonLabel}</span>
  <kbd class="hidden lg:inline ml-1 px-1.5 py-0.5 text-[9px] font-mono rounded border border-white/10 bg-white/[0.04] text-[var(--color-dim)]">⌘K</kbd>
</button>

<dialog
  id="search-modal"
  data-empty-hint={emptyHint}
  data-no-results={noResults}
  class="search-modal fixed top-4 sm:top-[15vh] left-1/2 -translate-x-1/2 m-0 w-[calc(100vw-1rem)] sm:w-full max-w-2xl rounded-2xl border border-white/10 bg-[var(--color-surface)]/95 backdrop-blur-xl shadow-2xl shadow-black/60 text-[var(--color-text)] p-0 outline-none"
>
  <form method="dialog">
    <div class="flex items-center gap-3 px-5 py-4 border-b border-white/10">
      <svg class="w-4 h-4 text-[var(--color-muted)]" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.4"/>
        <line x1="11" y1="11" x2="14" y2="14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder={placeholder}
        autocomplete="off"
        spellcheck="false"
        class="flex-1 bg-transparent border-0 outline-none text-base text-white placeholder:text-[var(--color-dim)]"
      />
      <button type="submit" aria-label="Close" class="text-[10px] font-mono px-1.5 py-0.5 rounded border border-white/15 text-[var(--color-muted)] hover:text-white hover:border-white/30">
        ESC
      </button>
    </div>

    <div id="search-results" class="max-h-[70vh] sm:max-h-[50vh] overflow-y-auto px-2 py-2 text-sm">
      <div class="px-3 py-6 text-center text-[var(--color-dim)]">{emptyHint}</div>
    </div>
  </form>
</dialog>

<style is:global>
  .search-modal::backdrop {
    background: rgba(5, 5, 10, 0.7);
    backdrop-filter: blur(6px);
  }
  .search-modal[open] {
    animation: search-pop 180ms ease-out;
  }
  @keyframes search-pop {
    from { opacity: 0; transform: translate(-50%, -8px); }
    to   { opacity: 1; transform: translate(-50%, 0); }
  }
  .search-result {
    display: block;
    padding: 0.75rem 0.9rem;
    border-radius: 8px;
    color: var(--color-muted);
    border-left: 2px solid transparent;
    transition: background 150ms, color 150ms, border-color 150ms;
  }
  .search-result[data-selected="true"],
  .search-result:hover {
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
    border-left-color: var(--color-brand-1);
  }
  .search-result-title {
    color: #fff;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.15rem;
  }
  .search-result-excerpt {
    font-size: 0.75rem;
    line-height: 1.55;
    color: var(--color-muted);
  }
  .search-result-excerpt mark {
    background: rgba(34, 211, 238, 0.2);
    color: #fff;
    padding: 0 0.15em;
    border-radius: 2px;
  }
</style>

<script>
  const trigger = document.querySelector<HTMLButtonElement>("[data-search-trigger]");
  const modal = document.getElementById("search-modal") as HTMLDialogElement | null;
  const input = document.getElementById("search-input") as HTMLInputElement | null;
  const results = document.getElementById("search-results");

  if (!trigger || !modal || !input || !results) {
    // Page has no search modal (shouldn't happen with shared header) — bail.
    console.debug("[search] modal markup missing");
  } else {
    const emptyHint = modal.dataset.emptyHint || "";
    const noResultsLabel = modal.dataset.noResults || "No results";

    let pagefind: any = null;
    async function ensurePagefind() {
      if (pagefind) return pagefind;
      try {
        // Pagefind ships its runtime under /pagefind/pagefind.js after the build step.
        // The URL is constructed at runtime so Rollup can't statically resolve it.
        const pagefindUrl = "/pagefind/" + "pagefind.js";
        pagefind = await import(/* @vite-ignore */ pagefindUrl);
        await pagefind.options({ excerptLength: 24 });
        return pagefind;
      } catch (e) {
        console.warn("[search] pagefind failed to load — was the index built?", e);
        return null;
      }
    }

    function open() {
      if (!modal!.open) modal!.showModal();
      setTimeout(() => input!.focus(), 30);
      ensurePagefind();
    }
    function close() {
      if (modal!.open) modal!.close();
    }

    trigger.addEventListener("click", open);

    // Cmd+K / Ctrl+K
    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && (e.key === "k" || e.key === "K")) {
        e.preventDefault();
        modal!.open ? close() : open();
      }
      if (e.key === "/" && document.activeElement === document.body) {
        e.preventDefault();
        open();
      }
    });

    // Close when clicking the backdrop
    modal.addEventListener("click", (e) => {
      const rect = modal.getBoundingClientRect();
      const inside =
        e.clientX >= rect.left &&
        e.clientX <= rect.right &&
        e.clientY >= rect.top &&
        e.clientY <= rect.bottom;
      if (!inside) close();
    });

    let active = -1;
    let currentLinks: HTMLAnchorElement[] = [];

    function renderResults(items: { url: string; title: string; excerpt: string }[]) {
      if (!items.length) {
        results!.innerHTML = `<div class="px-3 py-6 text-center text-[var(--color-dim)]">${noResultsLabel}</div>`;
        currentLinks = [];
        active = -1;
        return;
      }
      results!.innerHTML = items
        .map(
          (r, i) => `
            <a href="${r.url}" class="search-result" data-idx="${i}">
              <div class="search-result-title">${r.title || "Untitled"}</div>
              <div class="search-result-excerpt">${r.excerpt}</div>
            </a>`,
        )
        .join("");
      currentLinks = Array.from(results!.querySelectorAll<HTMLAnchorElement>(".search-result"));
      active = 0;
      currentLinks[0]?.setAttribute("data-selected", "true");
    }

    function setActive(next: number) {
      if (!currentLinks.length) return;
      currentLinks[active]?.removeAttribute("data-selected");
      active = (next + currentLinks.length) % currentLinks.length;
      currentLinks[active]?.setAttribute("data-selected", "true");
      currentLinks[active]?.scrollIntoView({ block: "nearest" });
    }

    input.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") {
        e.preventDefault();
        setActive(active + 1);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        setActive(active - 1);
      } else if (e.key === "Enter") {
        e.preventDefault();
        currentLinks[active]?.click();
      }
    });

    let searchTimer: number | undefined;
    input.addEventListener("input", () => {
      clearTimeout(searchTimer);
      const q = input!.value.trim();
      if (!q) {
        results!.innerHTML = `<div class="px-3 py-6 text-center text-[var(--color-dim)]">${emptyHint}</div>`;
        currentLinks = [];
        active = -1;
        return;
      }
      searchTimer = window.setTimeout(async () => {
        const pf = await ensurePagefind();
        if (!pf) {
          results!.innerHTML = `<div class="px-3 py-6 text-center text-[var(--color-dim)]">${noResultsLabel}</div>`;
          return;
        }
        const search = await pf.search(q);
        const items = await Promise.all(
          search.results.slice(0, 10).map(async (r: any) => {
            const data = await r.data();
            return {
              url: data.url,
              title: data.meta?.title || data.url,
              excerpt: data.excerpt,
            };
          }),
        );
        renderResults(items);
      }, 120);
    });

    // Reset state on close
    modal.addEventListener("close", () => {
      input!.value = "";
      results!.innerHTML = `<div class="px-3 py-6 text-center text-[var(--color-dim)]">${emptyHint}</div>`;
      currentLinks = [];
      active = -1;
    });
  }
</script>
