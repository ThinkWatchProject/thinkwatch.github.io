---
import "~/styles/global.css";
import { getLang, t } from "~/i18n";
import Seo from "~/components/Seo.astro";

const lang = getLang(Astro);
const i18n = t(lang);

type JsonLdItem = Record<string, unknown>;

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** Suppress the default SoftwareApplication JSON-LD (e.g. on subpages where it would be redundant). */
  noJsonLd?: boolean;
  /** Additional JSON-LD items to inject (BreadcrumbList, TechArticle, etc.) */
  jsonLd?: JsonLdItem[];
}

const DEFAULT_TITLE =
  lang === "zh-CN"
    ? "ThinkWatch — 面向 AI 的企业级安全网关"
    : "ThinkWatch — The enterprise-grade secure gateway for AI";

const DEFAULT_DESCRIPTION =
  lang === "zh-CN"
    ? "集中认证、审计并治理组织内每一次 AI API 调用与 MCP 工具调用 —— 由同一控制平面完成。"
    : "Secure, audit, and govern every AI API call and MCP tool invocation across your organization — from a single control plane.";

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  ogImage = "/og-image.png",
  noJsonLd = false,
  jsonLd: extraJsonLd = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const softwareApplicationLd: JsonLdItem = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "ThinkWatch",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Linux, macOS, Windows (via Docker / Kubernetes)",
  description,
  url: "https://thinkwat.ch",
  downloadUrl: "https://github.com/ThinkWatchProject/ThinkWatch",
  softwareVersion: "0.1.0",
  license: "https://github.com/ThinkWatchProject/ThinkWatch/blob/main/LICENSE",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  author: {
    "@type": "Organization",
    name: "ThinkWatch Project",
    url: "https://github.com/ThinkWatchProject",
  },
};

const jsonLd: JsonLdItem[] = noJsonLd
  ? [...extraJsonLd]
  : [softwareApplicationLd, ...extraJsonLd];

const GA_ID = "G-R8LX8NCHCJ";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!--
      Auto-redirect to the user's preferred locale.
      Runs synchronously before paint so there's no flash.
      Manual choice (set by the language dropdown) always wins.
    -->
    <script is:inline>
      (function () {
        try {
          var path = location.pathname;
          var isZh = path === "/zh-CN" || path.indexOf("/zh-CN/") === 0;
          var stored = localStorage.getItem("tw-lang-pref");
          var want;
          if (stored === "en" || stored === "zh-CN") {
            want = stored;
          } else {
            var l = (navigator.language || "en").toLowerCase();
            want = l.indexOf("zh") === 0 ? "zh-CN" : "en";
          }
          if (want === "zh-CN" && !isZh) {
            location.replace("/zh-CN" + (path === "/" ? "" : path) + location.search + location.hash);
          } else if (want === "en" && isZh) {
            var stripped = path.replace(/^\/zh-CN/, "") || "/";
            location.replace(stripped + location.search + location.hash);
          }
        } catch (e) {}
      })();
    </script>

    <Seo
      title={title}
      description={description}
      ogImage={ogImage}
      canonical={canonical}
      lang={lang}
      jsonLd={jsonLd}
    />

    <!--
      Google Analytics (gtag). Honors Do Not Track and loads async so it
      never blocks first paint. No personal data is sent until the library
      has loaded.
    -->
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline define:vars={{ GA_ID }}>
      (function () {
        try {
          if (navigator.doNotTrack === "1" || window.doNotTrack === "1") return;
        } catch (e) {}
        window.dataLayer = window.dataLayer || [];
        function gtag() { window.dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag("js", new Date());
        gtag("config", GA_ID, { anonymize_ip: true });
      })();
    </script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:px-4 focus:py-2 focus:rounded-lg focus:bg-brand-gradient focus:text-black focus:font-medium focus:shadow-xl"
    >
      {i18n.common.skipToContent}
    </a>
    <slot />
  </body>
</html>
