---
import { getLang, t, localePath } from "~/i18n";

const lang = getLang(Astro);
const s = t(lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 mt-32">
  <div class="container-page py-12 grid gap-10 md:grid-cols-4 text-sm">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2 mb-3">
        <svg class="w-6 h-6 shrink-0" viewBox="0 0 200 200" fill="none" aria-hidden="true">
          <rect width="200" height="200" rx="40" fill="#1E2A4A"/>
          <rect x="32" y="32" width="136" height="136" rx="28" fill="none" stroke="#3DDBD9" stroke-width="10"/>
          <line x1="62" y1="68" x2="138" y2="68" stroke="#3DDBD9" stroke-width="12" stroke-linecap="round"/>
          <line x1="100" y1="68" x2="100" y2="104" stroke="#3DDBD9" stroke-width="12" stroke-linecap="round"/>
          <polyline points="62,104 80,140 100,104" fill="none" stroke="#3DDBD9" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
          <polyline points="100,104 120,140 138,104" fill="none" stroke="#3DDBD9" stroke-width="12" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="text-white"><span class="font-medium">Think</span><span class="font-bold">Watch</span></span>
      </div>
      <p class="text-[var(--color-muted)] max-w-sm">
        {s.footer.tagline}
      </p>
    </div>

    <div>
      <div class="text-white/80 font-medium mb-3">{s.footer.product}</div>
      <ul class="space-y-2 text-[var(--color-muted)]">
        <li><a href="#features" class="hover:text-white">{s.nav.features}</a></li>
        <li><a href="#how" class="hover:text-white">{s.nav.how}</a></li>
        <li><a href="#quickstart" class="hover:text-white">{s.nav.quickstart}</a></li>
        <li><a href={localePath(lang, "/docs")} class="hover:text-white">{s.nav.docs}</a></li>
        <li><a href={localePath(lang, "/changelog")} class="hover:text-white">{s.nav.changelog}</a></li>
      </ul>
    </div>

    <div>
      <div class="text-white/80 font-medium mb-3">{s.footer.resources}</div>
      <ul class="space-y-2 text-[var(--color-muted)]">
        <li><a href="https://github.com/ThinkWatchProject/ThinkWatch" class="hover:text-white">GitHub</a></li>
        <li><a href="https://github.com/ThinkWatchProject/ThinkWatch/blob/main/LICENSE" class="hover:text-white">LICENSE (BSL 1.1)</a></li>
        <li><a href="https://github.com/ThinkWatchProject/ThinkWatch/blob/main/LICENSING.md" class="hover:text-white">Production thresholds</a></li>
        <li><a href="/changelog.xml" class="hover:text-white">RSS</a></li>
      </ul>
    </div>
  </div>

  <div class="container-page py-6 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-[var(--color-dim)]">
    <span>© {year} ThinkWatch. {s.footer.copyright}</span>
    <span>{s.footer.builtWith}</span>
  </div>
</footer>
