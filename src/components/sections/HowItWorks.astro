---
import { getLang, t } from "~/i18n";

const s = t(getLang(Astro)).how;

const clients = [
  { name: "Claude Code", color: "#22D3EE" },
  { name: "Cursor", color: "#67E8F9" },
  { name: "Custom Agent", color: "#A78BFA" },
  { name: "CI/CD Pipeline", color: "#C4B5FD" },
];

const providers = [
  { name: "OpenAI", color: "#10A37F" },
  { name: "Anthropic", color: "#D97706" },
  { name: "Google Gemini", color: "#4285F4" },
  { name: "Azure / Bedrock", color: "#A78BFA" },
];
---

<section id="how" class="py-20 sm:py-28 border-t border-white/5 relative overflow-hidden">
  <div class="container-page relative z-10">
    <div class="max-w-3xl">
      <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-brand-1)] font-medium mb-4">
        {s.eyebrow}
      </div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight">
        {s.title}<span class="text-gradient">{s.titleHighlight}</span>.
      </h2>
      <p class="mt-4 sm:mt-5 text-base sm:text-lg text-[var(--color-muted)] leading-relaxed">
        {s.sub}
      </p>
    </div>

    <!-- Architecture diagram -->
    <div class="mt-16 rounded-3xl border border-white/10 bg-[var(--color-surface)]/40 p-6 md:p-10 backdrop-blur-sm">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto_1fr] gap-6 md:gap-10 items-center">
        <div class="space-y-3">
          <div class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-dim)] mb-3">{s.callersLabel}</div>
          {clients.map((c) => (
            <div class="flex items-center gap-3 rounded-lg border border-white/10 bg-black/30 px-4 py-3">
              <span class="w-2 h-2 rounded-full" style={`background:${c.color}`} aria-hidden="true"></span>
              <span class="font-mono text-sm">{c.name}</span>
              <span class="ml-auto text-[10px] text-[var(--color-dim)] font-mono" aria-hidden="true"><span class="hidden lg:inline">→</span><span class="lg:hidden">↓</span></span>
            </div>
          ))}
        </div>

        <div class="relative arch-gateway">
          <!-- Animated horizontal connectors (desktop) -->
          <svg
            class="hidden lg:block absolute top-1/2 -left-12 -translate-y-1/2 pointer-events-none"
            width="48" height="2" aria-hidden="true"
          >
            <line x1="0" y1="1" x2="48" y2="1" stroke="url(#flow-l)" stroke-width="1.5" stroke-dasharray="3 4" class="arch-flow" />
            <defs>
              <linearGradient id="flow-l" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#22D3EE" stop-opacity="0"/>
                <stop offset="100%" stop-color="#22D3EE"/>
              </linearGradient>
            </defs>
          </svg>
          <svg
            class="hidden lg:block absolute top-1/2 -right-12 -translate-y-1/2 pointer-events-none"
            width="48" height="2" aria-hidden="true"
          >
            <line x1="0" y1="1" x2="48" y2="1" stroke="url(#flow-r)" stroke-width="1.5" stroke-dasharray="3 4" class="arch-flow arch-flow-reverse" />
            <defs>
              <linearGradient id="flow-r" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#A78BFA"/>
                <stop offset="100%" stop-color="#A78BFA" stop-opacity="0"/>
              </linearGradient>
            </defs>
          </svg>
          <!-- Mobile vertical connectors -->
          <div class="lg:hidden absolute left-1/2 -top-6 h-6 w-px bg-gradient-to-b from-transparent to-[var(--color-brand-1)]"></div>
          <div class="lg:hidden absolute left-1/2 -bottom-6 h-6 w-px bg-gradient-to-t from-transparent to-[var(--color-brand-2)]"></div>

          <div class="relative rounded-2xl p-[1.5px] bg-gradient-to-br from-[var(--color-brand-1)] via-[var(--color-brand-2)] to-[var(--color-accent)] arch-glow">
            <div class="rounded-2xl bg-[var(--color-bg)] p-6 min-w-[220px] text-center">
              <div class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-dim)] mb-2">{s.gatewayPort}</div>
              <div class="font-semibold text-lg mb-1">{s.gatewayName}</div>
              <div class="text-xs text-[var(--color-muted)] font-mono">{s.gatewayTagline}</div>

              <div class="mt-5 grid grid-cols-2 gap-1.5 text-[10px] font-mono text-[var(--color-muted)]">
                <span class="rounded bg-white/5 px-2 py-1">/v1/chat</span>
                <span class="rounded bg-white/5 px-2 py-1">/v1/messages</span>
                <span class="rounded bg-white/5 px-2 py-1">/v1/responses</span>
                <span class="rounded bg-white/5 px-2 py-1">/mcp</span>
              </div>
            </div>
          </div>
        </div>

        <div class="space-y-3">
          <div class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-dim)] mb-3 lg:text-right">{s.upstreamsLabel}</div>
          {providers.map((p) => (
            <div class="flex items-center gap-3 rounded-lg border border-white/10 bg-black/30 px-4 py-3">
              <span class="text-[10px] text-[var(--color-dim)] font-mono" aria-hidden="true"><span class="hidden lg:inline">→</span><span class="lg:hidden">↓</span></span>
              <span class="font-mono text-sm">{p.name}</span>
              <span class="ml-auto w-2 h-2 rounded-full" style={`background:${p.color}`} aria-hidden="true"></span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Pipeline rail -->
    <div class="mt-16">
      <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)] mb-6">{s.pipelineLabel}</div>

      <div class="pipeline-rail relative h-px bg-white/10 overflow-hidden mb-6">
        <div class="pipeline-rail-fill absolute inset-y-0 left-0 bg-gradient-to-r from-[var(--color-brand-1)] via-[var(--color-brand-2)] to-[var(--color-accent)] transition-[width] duration-500 ease-[cubic-bezier(.22,.9,.3,1)]" style="width: 16.66%"></div>
      </div>

      <ol class="pipeline-steps grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6" role="tablist">
        {s.pipeline.map((step, i) => (
          <li>
            <button
              type="button"
              class="pipeline-step group w-full text-left py-4 pr-4 sm:pr-5 border-r border-white/10 last:border-r-0 transition-colors"
              data-pipeline-step={i}
              aria-label={`Pipeline step ${step.step}: ${step.label}`}
            >
              <div class="flex items-center justify-between mb-3">
                <span class="pipeline-step-num font-mono text-[11px] tracking-[0.12em] text-[var(--color-dim)] transition-colors">{step.step}</span>
                <span class="pipeline-step-tick w-2 h-2 rounded-full bg-white/15 transition-all" aria-hidden="true"></span>
              </div>
              <h4 class="pipeline-step-title font-medium text-sm text-white mb-1.5 tracking-tight">{step.label}</h4>
              <p class="text-xs text-[var(--color-muted)] leading-[1.55]" set:html={step.body.replace(/`([^`]+)`/g, '<code class="font-mono text-[11px] text-[var(--color-brand-1)] bg-white/5 rounded px-1 py-0.5">$1</code>')}></p>
            </button>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .pipeline-step {
    opacity: 0.55;
    cursor: pointer;
    background: transparent;
    border: 0;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    font-family: inherit;
    transition: opacity 300ms ease;
  }
  .pipeline-step:hover { opacity: 0.85; }
  .pipeline-step.is-active,
  .pipeline-step.is-done { opacity: 1; }
  .pipeline-step.is-active .pipeline-step-num { color: var(--color-brand-1); }
  .pipeline-step.is-active .pipeline-step-tick {
    background: var(--color-brand-1);
    box-shadow: 0 0 14px var(--color-brand-1);
  }
  .pipeline-step.is-done .pipeline-step-tick { background: var(--color-brand-2); }

  @media (prefers-reduced-motion: reduce) {
    .pipeline-rail-fill,
    .pipeline-step { transition: none !important; }
    .arch-flow,
    .arch-glow { animation: none !important; }
  }

  @keyframes archDash {
    to { stroke-dashoffset: -28; }
  }
  @keyframes archDashReverse {
    to { stroke-dashoffset: 28; }
  }
  .arch-flow {
    animation: archDash 1.4s linear infinite;
  }
  .arch-flow-reverse {
    animation: archDashReverse 1.4s linear infinite;
  }

  @keyframes archGlow {
    0%, 100% { filter: drop-shadow(0 0 18px rgba(34, 211, 238, 0.25)) drop-shadow(0 0 28px rgba(167, 139, 250, 0.18)); }
    50%      { filter: drop-shadow(0 0 28px rgba(34, 211, 238, 0.45)) drop-shadow(0 0 42px rgba(167, 139, 250, 0.28)); }
  }
  .arch-glow {
    animation: archGlow 3.6s ease-in-out infinite;
  }
</style>

<script>
  // Auto-advance the pipeline as the section scrolls into view; pause when out of
  // view. Users can click any step to jump there — the timer resumes afterwards.
  const section = document.getElementById("how");
  const steps = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-pipeline-step]")
  );
  const rail = document.querySelector<HTMLElement>(".pipeline-rail-fill");

  if (section && steps.length && rail) {
    const total = steps.length;
    let active = 0;
    let visible = false;
    let timer: number | undefined;

    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const render = () => {
      steps.forEach((el, i) => {
        el.classList.toggle("is-active", i === active);
        el.classList.toggle("is-done", i < active);
      });
      rail.style.width = `${((active + 1) / total) * 100}%`;
    };

    const schedule = () => {
      if (timer) window.clearTimeout(timer);
      if (!visible || prefersReduced) return;
      timer = window.setTimeout(() => {
        active = (active + 1) % total;
        render();
        schedule();
      }, 2400);
    };

    steps.forEach((el, i) =>
      el.addEventListener("click", () => {
        active = i;
        render();
        schedule();
      })
    );

    if ("IntersectionObserver" in window) {
      const obs = new IntersectionObserver(
        (entries) => {
          visible = entries[0]?.isIntersecting ?? false;
          schedule();
        },
        { threshold: 0.2 }
      );
      obs.observe(section);
    } else {
      visible = true;
      schedule();
    }

    render();
  }
</script>
