---
import TiltCard from "../ui/TiltCard.tsx";
import { getLang, t } from "~/i18n";

const s = t(getLang(Astro)).problem;
---

<section id="problem" class="py-20 sm:py-28 border-t border-white/5 relative">
  <div class="container-page relative z-10">
    <div class="max-w-3xl">
      <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-accent)] font-medium mb-4">
        {s.eyebrow}
      </div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight">
        {s.title}<span class="text-gradient">{s.titleHighlight}</span>.
      </h2>
      <p class="mt-4 sm:mt-5 text-base sm:text-lg text-[var(--color-muted)] leading-relaxed">
        {s.sub}
      </p>
    </div>

    <div class="mt-12 sm:mt-16 grid gap-4 sm:gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {s.pains.map((p, i) => (
        <div class="pain-item" style={`--pain-delay:${i * 80}ms`}>
          <TiltCard client:visible className="rounded-2xl">
            <div class="relative rounded-2xl border border-white/10 bg-[var(--color-surface)]/60 p-5 sm:p-6 hover:border-white/25 transition-colors overflow-hidden h-full">
              <div class="flex items-start justify-between mb-4">
                <div class="text-3xl grayscale group-hover:grayscale-0 transition" aria-hidden="true">
                  {p.icon}
                </div>
                <span class="font-mono text-[11px] tracking-[0.12em] text-[var(--color-dim)]">
                  {String(i + 1).padStart(2, "0")}
                </span>
              </div>
              <h3 class="text-lg font-semibold tracking-tight mb-2">{p.title}</h3>
              <p class="text-sm text-[var(--color-muted)] leading-relaxed">{p.body}</p>
              <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-pink-400/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
          </TiltCard>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-[var(--color-muted)]">
        {s.footer[0]}<span class="text-white font-medium">{s.footer[1]}</span>{s.footer[2]}
      </p>
    </div>
  </div>
</section>

<style>
  .pain-item {
    opacity: 0;
    transform: translateY(14px);
  }
  .pain-item.is-visible {
    animation: painFadeUp 600ms cubic-bezier(.2,.7,.25,1) both;
    animation-delay: var(--pain-delay, 0ms);
  }
  @keyframes painFadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pain-item { opacity: 1; transform: none; animation: none !important; }
  }
</style>

<script>
  const cards = document.querySelectorAll(".pain-item");
  if (cards.length && "IntersectionObserver" in window) {
    const obs = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            obs.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15 }
    );
    cards.forEach((c) => obs.observe(c));
  } else {
    cards.forEach((c) => c.classList.add("is-visible"));
  }
</script>
