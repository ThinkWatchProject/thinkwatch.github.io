---
import { getCollection, render } from "astro:content";
import DocsLayout from "~/layouts/DocsLayout.astro";
import { docsOrder, findDoc } from "~/content/docs/_meta";

export async function getStaticPaths() {
  const all = await getCollection("docs");
  const entries = all.filter((e) => e.id.toLowerCase().startsWith("zh-cn/"));
  return entries.map((entry) => {
    const slug = entry.id.replace(/^zh-CN\//i, "").replace(/\.md$/, "");
    return {
      params: { slug },
      props: { entry, slug },
    };
  });
}

const { entry, slug } = Astro.props;
const meta = findDoc(slug);
const { Content, headings } = await render(entry);

// In zh-CN reading order, skip docs that don't have a Chinese translation.
const zhDocs = docsOrder.filter((d) => d.locales.includes("zh-CN"));
const idx = zhDocs.findIndex((d) => d.slug === slug);
const prev = idx > 0 ? zhDocs[idx - 1] : undefined;
const next = idx >= 0 && idx < zhDocs.length - 1 ? zhDocs[idx + 1] : undefined;

const title = meta ? `${meta.label["zh-CN"]} · ThinkWatch 文档` : "ThinkWatch 文档";
const description = meta?.summary?.["zh-CN"];
---

<DocsLayout
  title={title}
  description={description}
  current={slug}
  headings={headings}
  prev={prev}
  next={next}
>
  <Content />
</DocsLayout>
