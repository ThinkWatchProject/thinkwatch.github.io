---
import { getLang, t, localePath, type Lang } from "~/i18n";
import { getStarCount, formatStars } from "~/lib/github";

const lang = getLang(Astro);
const s = t(lang);
const stars = await getStarCount();
const starLabel = formatStars(stars);

const links = [
  { href: "#how", label: s.nav.how },
  { href: "#features", label: s.nav.features },
  { href: "#dashboard", label: s.nav.console },
  { href: "#quickstart", label: s.nav.quickstart },
  { href: localePath(lang, "/changelog"), label: s.nav.changelog },
];

const cleanPath = Astro.url.pathname.replace(/^\/zh-CN/, "") || "/";

const langOptions: { code: Lang; label: string; native: string }[] = [
  { code: "en", label: "English", native: "EN" },
  { code: "zh-CN", label: "简体中文", native: "中文" },
];
const currentLangOption = langOptions.find((l) => l.code === lang)!;
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-[var(--color-bg)]/60 border-b border-white/5">
  <div class="container-page flex items-center justify-between h-16">
    <a href={localePath(lang, "/")} class="flex items-center gap-2 group">
      <span class="relative inline-block w-7 h-7 rounded-md bg-brand-gradient glow" aria-hidden="true"></span>
      <span class="font-semibold tracking-tight text-lg">
        Think<span class="text-gradient">Watch</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm text-[var(--color-muted)]">
      {links.map((l) => (
        <a href={l.href} class="hover:text-white transition-colors">{l.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <!-- Language dropdown — pure HTML <details>, no JS -->
      <details class="lang-menu relative">
        <summary
          class="list-none cursor-pointer select-none flex items-center gap-1.5 text-xs font-medium text-[var(--color-muted)] hover:text-white border border-white/10 hover:border-white/25 rounded-md px-2.5 py-1.5 transition-colors"
          aria-label="Switch language"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/>
            <path d="M1.5 8h13M8 1.5c2 2 2 11 0 13M8 1.5c-2 2-2 11 0 13" stroke="currentColor" stroke-width="1.2"/>
          </svg>
          <span>{currentLangOption.native}</span>
          <svg class="w-3 h-3 transition-transform" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <div class="absolute right-0 mt-2 w-44 rounded-lg border border-white/10 bg-[var(--color-surface)] shadow-2xl shadow-black/40 backdrop-blur-lg overflow-hidden z-50">
          {langOptions.map((opt) => {
            const href = localePath(opt.code, cleanPath);
            const isActive = opt.code === lang;
            return (
              <a
                href={href}
                hreflang={opt.code}
                class:list={[
                  "flex items-center justify-between gap-3 px-3.5 py-2.5 text-sm transition-colors",
                  isActive
                    ? "text-white bg-white/[0.06]"
                    : "text-[var(--color-muted)] hover:text-white hover:bg-white/[0.04]",
                ]}
              >
                <span>{opt.label}</span>
                <span class="text-[10px] font-mono text-[var(--color-dim)]">{opt.native}</span>
              </a>
            );
          })}
        </div>
      </details>

      <!-- GitHub icon + star pill -->
      <a
        href="https://github.com/ThinkWatchProject/ThinkWatch"
        target="_blank"
        rel="noopener"
        aria-label={`GitHub repository — ${stars ?? 0} stars`}
        class="group flex items-center gap-1.5 text-xs font-medium text-[var(--color-muted)] hover:text-white border border-white/10 hover:border-white/25 rounded-md pl-2 pr-2.5 py-1.5 transition-colors"
      >
        <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        <svg class="w-3 h-3 text-amber-300" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
        </svg>
        <span class="tabular-nums">{starLabel}</span>
      </a>

      <a
        href="#quickstart"
        class="text-sm font-medium px-4 py-2 rounded-lg bg-brand-gradient text-black hover:brightness-110 transition"
      >
        {s.common.getStarted}
      </a>
    </div>
  </div>
</header>

<style>
  .lang-menu summary::-webkit-details-marker { display: none; }
  .lang-menu[open] summary svg:last-child { transform: rotate(180deg); }
  .lang-menu[open] summary { color: white; border-color: rgba(255, 255, 255, 0.25); }
</style>

<script>
  // Click-outside dismissal for the language menu
  document.querySelectorAll<HTMLDetailsElement>("details.lang-menu").forEach((d) => {
    document.addEventListener("click", (e) => {
      if (!d.contains(e.target as Node)) d.open = false;
    });
  });
</script>
