---
import { getCollection, render } from "astro:content";
import DocsLayout from "~/layouts/DocsLayout.astro";
import { findDoc } from "~/content/docs/_meta";

export async function getStaticPaths() {
  const all = await getCollection("docs");
  const entries = all.filter((e) => e.id.toLowerCase().startsWith("en/"));
  return entries.map((entry) => {
    const slug = entry.id.replace(/^en\//i, "").replace(/\.md$/, "");
    return {
      params: { slug },
      props: { entry, slug },
    };
  });
}

const { entry, slug } = Astro.props;
const meta = findDoc(slug);
const { Content } = await render(entry);

const title = meta ? `${meta.label.en} · ThinkWatch Docs` : "ThinkWatch Docs";
const description = meta?.summary?.en;
---

<DocsLayout title={title} description={description} current={slug}>
  <Content />
</DocsLayout>
