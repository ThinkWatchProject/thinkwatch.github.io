---
// Re-uses the locale-aware /changelog page; Astro routes /zh-CN/changelog
// here. Importing the same module would duplicate the route, so we
// inline the same content with the locale already set by URL.
import { getCollection, render } from "astro:content";
import Base from "~/layouts/Base.astro";
import SiteHeader from "~/components/SiteHeader.astro";
import SiteFooter from "~/components/SiteFooter.astro";

const entries = (await getCollection("changelog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const typeStyles: Record<string, string> = {
  release: "bg-cyan-500/15 text-cyan-300 border-cyan-500/30",
  feature: "bg-violet-500/15 text-violet-300 border-violet-500/30",
  fix: "bg-emerald-500/15 text-emerald-300 border-emerald-500/30",
  security: "bg-pink-500/15 text-pink-300 border-pink-500/30",
};

const fmt = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const filterTypes = [
  { id: "all", label: "全部" },
  { id: "release", label: "发布" },
  { id: "feature", label: "新功能" },
  { id: "fix", label: "修复" },
  { id: "security", label: "安全" },
];
---

<Base title="更新日志 · ThinkWatch" description="ThinkWatch 的发布说明与更新。">
  <SiteHeader />
  <main id="main" class="container-page py-20">
    <div class="max-w-3xl">
      <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-brand-1)] font-medium mb-4">
        更新日志
      </div>
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight">
        最新 <span class="text-gradient">发布</span>
      </h1>
      <p class="mt-4 text-[var(--color-muted)] text-lg">
        每个发布版本的发布说明。可通过
        <a href="/changelog.xml" class="text-white underline underline-offset-4 hover:text-[var(--color-brand-1)]">RSS</a>
        订阅。
      </p>
    </div>

    <div class="mt-12 flex flex-wrap gap-2" role="tablist" aria-label="按类型筛选更新日志">
      {filterTypes.map((f, i) => (
        <button
          type="button"
          data-filter-btn={f.id}
          aria-pressed={i === 0 ? "true" : "false"}
          class:list={[
            "filter-btn px-3 py-1.5 rounded-full text-xs font-medium border transition-colors",
            i === 0
              ? "border-transparent bg-brand-gradient text-black"
              : "border-white/15 text-[var(--color-muted)] hover:text-white hover:border-white/30",
          ]}
        >
          {f.label}
        </button>
      ))}
    </div>

    <ol class="changelog-list mt-12 space-y-12 max-w-3xl" data-filter="all">
      {entries.map(async (entry) => {
        const { Content } = await render(entry);
        return (
          <li
            id={`v${entry.data.version}`}
            data-type={entry.data.type}
            class="changelog-item relative pl-8 border-l border-white/10 scroll-mt-24"
          >
            <a href={`#v${entry.data.version}`} class="absolute -left-[5px] top-2 w-2.5 h-2.5 rounded-full bg-brand-gradient ring-4 ring-[var(--color-bg)] hover:scale-125 transition-transform" aria-label={`链接到 v${entry.data.version}`}></a>

            <div class="flex flex-wrap items-center gap-3 mb-3">
              <span class="font-mono text-sm text-white">v{entry.data.version}</span>
              <span class={`text-[10px] uppercase tracking-wider px-2 py-0.5 rounded-full border ${typeStyles[entry.data.type]}`}>
                {entry.data.type}
              </span>
              <time class="text-xs text-[var(--color-dim)]" datetime={entry.data.date.toISOString()}>
                {fmt.format(entry.data.date)}
              </time>
            </div>

            <h2 class="text-2xl font-semibold tracking-tight mb-3">{entry.data.title}</h2>

            {entry.data.highlights && (
              <ul class="mb-4 space-y-1.5 text-sm text-[var(--color-muted)]">
                {entry.data.highlights.map((h) => (
                  <li class="flex gap-2">
                    <span class="text-[var(--color-brand-1)]" aria-hidden="true">›</span>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            )}

            <div class="prose prose-invert prose-sm max-w-none text-[var(--color-muted)]">
              <Content />
            </div>
          </li>
        );
      })}
    </ol>
  </main>
  <SiteFooter />
</Base>

<style>
  .changelog-list[data-filter="release"]  .changelog-item:not([data-type="release"]),
  .changelog-list[data-filter="feature"]  .changelog-item:not([data-type="feature"]),
  .changelog-list[data-filter="fix"]      .changelog-item:not([data-type="fix"]),
  .changelog-list[data-filter="security"] .changelog-item:not([data-type="security"]) {
    display: none;
  }
</style>

<script>
  const list = document.querySelector(".changelog-list");
  const buttons = document.querySelectorAll<HTMLButtonElement>("[data-filter-btn]");
  if (list && buttons.length) {
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.filterBtn || "all";
        list.setAttribute("data-filter", id);
        buttons.forEach((b) => {
          const active = b === btn;
          b.setAttribute("aria-pressed", active ? "true" : "false");
          b.classList.toggle("bg-brand-gradient", active);
          b.classList.toggle("text-black", active);
          b.classList.toggle("border-transparent", active);
          b.classList.toggle("border-white/15", !active);
          b.classList.toggle("text-[var(--color-muted)]", !active);
        });
      });
    });
  }
</script>
