---
import Base from "~/layouts/Base.astro";
import SiteHeader from "~/components/SiteHeader.astro";
import SiteFooter from "~/components/SiteFooter.astro";
---

<Base
  title="404 — Page not found · ThinkWatch"
  description="The page you were looking for could not be found."
>
  <SiteHeader />
  <main id="main" class="container-page py-32 text-center relative">
    <div class="absolute left-1/2 top-1/3 -translate-x-1/2 -translate-y-1/2 w-[34rem] h-[34rem] rounded-full bg-brand-gradient opacity-15 blur-[120px] pointer-events-none"></div>

    <div class="relative">
      <div class="text-[10rem] md:text-[14rem] font-semibold tracking-tighter leading-none">
        <span class="text-gradient">404</span>
      </div>
      <h1 class="mt-4 text-2xl md:text-3xl font-semibold tracking-tight">
        This route was not authorized.
      </h1>
      <p class="mt-4 text-[var(--color-muted)] max-w-md mx-auto">
        The page you were looking for does not exist — or was rate-limited, audited, and dropped at the gateway.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/"
          class="px-5 py-3 rounded-lg bg-brand-gradient text-black font-medium hover:brightness-110 transition shadow-lg shadow-cyan-500/20"
        >
          ← Back to home
        </a>
        <a
          href="/changelog"
          class="px-5 py-3 rounded-lg border border-white/15 hover:border-white/30 hover:bg-white/5 transition font-medium"
        >
          View changelog
        </a>
      </div>

      <pre class="mt-12 inline-block text-left font-mono text-xs text-[var(--color-dim)] bg-black/40 border border-white/10 rounded-lg px-4 py-3">
<span class="text-[var(--color-brand-1)]">$</span> curl -i https://thinkwat.ch{Astro.url.pathname}
HTTP/2 404
content-type: text/html
x-thinkwatch-audit: 01HQZ-NOT-FOUND</pre>
    </div>
  </main>
  <SiteFooter />
</Base>
