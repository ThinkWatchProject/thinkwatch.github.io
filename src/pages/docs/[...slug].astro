---
import { getCollection, render } from "astro:content";
import DocsLayout from "~/layouts/DocsLayout.astro";
import { docsOrder, findDoc } from "~/content/docs/_meta";

export async function getStaticPaths() {
  const all = await getCollection("docs");
  const entries = all.filter((e) => e.id.toLowerCase().startsWith("en/"));
  return entries.map((entry) => {
    const slug = entry.id.replace(/^en\//i, "").replace(/\.md$/, "");
    return {
      params: { slug },
      props: { entry, slug },
    };
  });
}

const { entry, slug } = Astro.props;
const meta = findDoc(slug);
const { Content, headings } = await render(entry);

const idx = docsOrder.findIndex((d) => d.slug === slug);
const prev = idx > 0 ? docsOrder[idx - 1] : undefined;
const next = idx >= 0 && idx < docsOrder.length - 1 ? docsOrder[idx + 1] : undefined;

const title = meta ? `${meta.label.en} · ThinkWatch Docs` : "ThinkWatch Docs";
const description = meta?.summary?.en;
---

<DocsLayout
  title={title}
  description={description}
  current={slug}
  headings={headings}
  prev={prev}
  next={next}
>
  <Content />
</DocsLayout>
