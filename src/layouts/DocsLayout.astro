---
import Base from "./Base.astro";
import SiteHeader from "~/components/SiteHeader.astro";
import SiteFooter from "~/components/SiteFooter.astro";
import { getSidebarForLocale, type DocMeta } from "~/content/docs/_meta";
import { getLang, localePath } from "~/i18n";

type Heading = { depth: number; slug: string; text: string };

interface Props {
  title: string;
  description?: string;
  /** Slug of the currently displayed doc, e.g. "architecture" */
  current: string;
  /** Headings extracted from rendered markdown (passed by the route) */
  headings?: Heading[];
  /** Previous and next docs in reading order (passed by the route) */
  prev?: DocMeta;
  next?: DocMeta;
  /** Extra JSON-LD items (BreadcrumbList, TechArticle, etc.) */
  jsonLd?: Record<string, unknown>[];
}

const { title, description, current, headings = [], prev, next, jsonLd = [] } = Astro.props;
const lang = getLang(Astro);
const docs = getSidebarForLocale(lang);

const baseHref = localePath(lang, "/docs");
const docsLabel = lang === "zh-CN" ? "文档" : "Documentation";
const tocLabel = lang === "zh-CN" ? "本页目录" : "On this page";
const prevLabel = lang === "zh-CN" ? "上一篇" : "Previous";
const nextLabel = lang === "zh-CN" ? "下一篇" : "Next";

// Only show H2/H3 in the TOC; hide if there's only the (auto-generated) doc title.
// rehype-autolink-headings appends a literal "#" text node to each heading,
// which Astro picks up as part of the heading text — strip it for display.
const tocHeadings = headings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => ({ ...h, text: h.text.replace(/#+\s*$/, "").trim() }));
---

<Base title={title} description={description} noJsonLd jsonLd={jsonLd}>
  <SiteHeader />
  <main id="main" class="container-page py-12 lg:py-16">
    <div class="grid lg:grid-cols-[14rem_minmax(0,1fr)_12rem] gap-8 xl:gap-12">
      <!-- Sidebar -->
      <aside class="lg:sticky lg:top-20 lg:self-start lg:max-h-[calc(100vh-6rem)] lg:overflow-y-auto">
        <div class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-brand-1)] font-medium mb-4">
          {docsLabel}
        </div>
        <nav aria-label="Documentation navigation">
          <ul class="space-y-1">
            <li>
              <a
                href={baseHref}
                class:list={[
                  "block px-3 py-2 rounded-md text-sm transition-colors",
                  current === ""
                    ? "bg-white/[0.06] text-white border-l-2 border-[var(--color-brand-1)]"
                    : "text-[var(--color-muted)] hover:text-white hover:bg-white/[0.03]",
                ]}
              >
                {lang === "zh-CN" ? "概览" : "Overview"}
              </a>
            </li>
            {docs.map((d) => {
              const isActive = d.slug === current;
              const href = d.availableHere ? `${baseHref}/${d.slug}` : `/docs/${d.slug}`;
              return (
                <li>
                  <a
                    href={href}
                    class:list={[
                      "flex items-center justify-between gap-2 px-3 py-2 rounded-md text-sm transition-colors",
                      isActive
                        ? "bg-white/[0.06] text-white border-l-2 border-[var(--color-brand-1)]"
                        : "text-[var(--color-muted)] hover:text-white hover:bg-white/[0.03] border-l-2 border-transparent",
                    ]}
                  >
                    <span>{d.label[lang]}</span>
                    {!d.availableHere && (
                      <span class="text-[9px] font-mono uppercase tracking-wider px-1.5 py-0.5 rounded bg-cyan-500/15 text-cyan-300 border border-cyan-500/30">
                        EN
                      </span>
                    )}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>

        <div class="mt-8 pt-6 border-t border-white/5 text-xs text-[var(--color-dim)]">
          <a
            href="https://github.com/ThinkWatchProject/ThinkWatch/tree/main/docs"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 hover:text-white transition-colors"
          >
            <svg class="w-3 h-3" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            {lang === "zh-CN" ? "在 GitHub 上编辑" : "Edit on GitHub"}
          </a>
        </div>
      </aside>

      <!-- Article -->
      <article class="prose-tw min-w-0" data-pagefind-body data-pagefind-meta={`title:${title.split(" · ")[0]}`}>
        <slot />

        {(prev || next) && (
          <nav class="not-prose mt-16 pt-8 border-t border-white/10 grid sm:grid-cols-2 gap-4" aria-label="Document navigation">
            {prev ? (
              <a
                href={prev.locales.includes(lang) ? `${baseHref}/${prev.slug}` : `/docs/${prev.slug}`}
                class="group rounded-xl border border-white/10 bg-[var(--color-surface)]/40 p-5 hover:border-white/25 hover:bg-[var(--color-surface)]/70 transition-colors"
              >
                <div class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-dim)] mb-1.5">← {prevLabel}</div>
                <div class="font-semibold tracking-tight text-white group-hover:text-[var(--color-brand-1)] transition-colors">
                  {prev.label[lang] || prev.label.en}
                </div>
              </a>
            ) : <span />}
            {next ? (
              <a
                href={next.locales.includes(lang) ? `${baseHref}/${next.slug}` : `/docs/${next.slug}`}
                class="group rounded-xl border border-white/10 bg-[var(--color-surface)]/40 p-5 hover:border-white/25 hover:bg-[var(--color-surface)]/70 transition-colors text-right"
              >
                <div class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-dim)] mb-1.5">{nextLabel} →</div>
                <div class="font-semibold tracking-tight text-white group-hover:text-[var(--color-brand-1)] transition-colors">
                  {next.label[lang] || next.label.en}
                </div>
              </a>
            ) : <span />}
          </nav>
        )}
      </article>

      <!-- TOC (right rail) -->
      {tocHeadings.length > 0 ? (
        <aside class="hidden lg:block lg:sticky lg:top-20 lg:self-start lg:max-h-[calc(100vh-6rem)] lg:overflow-y-auto">
          <div class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-brand-1)] font-medium mb-4">
            {tocLabel}
          </div>
          <nav aria-label="Table of contents">
            <ul class="space-y-1.5 text-sm border-l border-white/10">
              {tocHeadings.map((h) => (
                <li>
                  <a
                    href={`#${h.slug}`}
                    data-toc-link={h.slug}
                    class:list={[
                      "block py-1 transition-colors -ml-px border-l border-transparent hover:text-white hover:border-white/30",
                      h.depth === 2 ? "pl-4 text-[var(--color-muted)]" : "pl-7 text-[var(--color-dim)] text-[12.5px]",
                    ]}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      ) : <span />}
    </div>
  </main>
  <SiteFooter />
</Base>

<style is:global>
  .toc-link-active {
    color: #fff !important;
    border-color: var(--color-brand-1) !important;
  }

  /* Code copy button (injected by client script) */
  .code-block-wrap {
    position: relative;
  }
  .code-copy-btn {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    padding: 0.35rem 0.55rem;
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--color-muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    cursor: pointer;
    opacity: 0;
    transition: opacity 200ms, color 150ms, border-color 150ms, background 150ms;
  }
  .code-block-wrap:hover .code-copy-btn,
  .code-copy-btn:focus {
    opacity: 1;
  }
  .code-copy-btn:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.08);
  }
  .code-copy-btn[data-copied="true"] {
    color: #6ee7b7;
    border-color: rgba(110, 231, 183, 0.4);
    background: rgba(110, 231, 183, 0.1);
    opacity: 1;
  }
</style>

<script>
  // Wrap every code block with a "Copy" button.
  const copyLabel = document.documentElement.lang === "zh-CN" ? "复制" : "Copy";
  const copiedLabel = document.documentElement.lang === "zh-CN" ? "已复制" : "Copied";

  document.querySelectorAll<HTMLPreElement>("article pre.astro-code, article pre.shiki").forEach((pre) => {
    if (pre.parentElement?.classList.contains("code-block-wrap")) return;
    const wrap = document.createElement("div");
    wrap.className = "code-block-wrap";
    pre.parentElement?.insertBefore(wrap, pre);
    wrap.appendChild(pre);

    const btn = document.createElement("button");
    btn.type = "button";
    btn.className = "code-copy-btn";
    btn.textContent = copyLabel;
    btn.setAttribute("aria-label", copyLabel);
    btn.addEventListener("click", async () => {
      const text = pre.innerText;
      try {
        await navigator.clipboard.writeText(text);
        btn.textContent = copiedLabel;
        btn.dataset.copied = "true";
        setTimeout(() => {
          btn.textContent = copyLabel;
          delete btn.dataset.copied;
        }, 1500);
      } catch {
        btn.textContent = "!";
      }
    });
    wrap.appendChild(btn);
  });
</script>

<script>
  // Scroll-based scrollspy: more reliable than IntersectionObserver for long
  // docs with sparse headings, and lets us also auto-scroll the TOC's own
  // overflowing list to keep the active item in view.
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"));
  const linkBySlug = new Map<string, HTMLAnchorElement>();
  links.forEach((l) => linkBySlug.set(l.dataset.tocLink || "", l));

  const headings = Array.from(document.querySelectorAll<HTMLElement>("article h2, article h3")).filter(
    (h) => h.id && linkBySlug.has(h.id),
  );

  if (links.length && headings.length) {
    let active: HTMLAnchorElement | null = null;
    const tocAside = links[0].closest("aside") as HTMLElement | null;

    function scrollLinkIntoTocView(link: HTMLAnchorElement) {
      if (!tocAside) return;
      const linkRect = link.getBoundingClientRect();
      const asideRect = tocAside.getBoundingClientRect();
      const margin = 24;
      if (linkRect.top < asideRect.top + margin) {
        tocAside.scrollTop -= asideRect.top + margin - linkRect.top;
      } else if (linkRect.bottom > asideRect.bottom - margin) {
        tocAside.scrollTop += linkRect.bottom - (asideRect.bottom - margin);
      }
    }

    function setActive(slug: string) {
      const next = linkBySlug.get(slug);
      if (!next || next === active) return;
      active?.classList.remove("toc-link-active");
      active = next;
      active.classList.add("toc-link-active");
      scrollLinkIntoTocView(active);
    }

    // Header is sticky at top: 5rem (80px). Treat anything within 120px of
    // the viewport top as the "current" section.
    const TRIGGER_OFFSET = 120;

    function update() {
      const triggerY = window.scrollY + TRIGGER_OFFSET;
      let currentSlug = headings[0].id;
      for (const h of headings) {
        if (h.offsetTop <= triggerY) {
          currentSlug = h.id;
        } else {
          break;
        }
      }
      setActive(currentSlug);
    }

    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        update();
        ticking = false;
      });
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    // Run once on init
    update();

    // When the user clicks a TOC link, immediately mark it active so it
    // doesn't lag behind the smooth-scroll animation.
    links.forEach((link) => {
      link.addEventListener("click", () => {
        const slug = link.dataset.tocLink;
        if (slug) setActive(slug);
      });
    });
  }
</script>
