---
import { getCollection, render } from "astro:content";
import DocsLayout from "~/layouts/DocsLayout.astro";
import { docsOrder, findDoc } from "~/content/docs/_meta";

export async function getStaticPaths() {
  const all = await getCollection("docs");
  const entries = all.filter((e) => e.id.toLowerCase().startsWith("zh-cn/"));
  return entries.map((entry) => {
    const slug = entry.id.replace(/^zh-CN\//i, "").replace(/\.md$/, "");
    return {
      params: { slug },
      props: { entry, slug },
    };
  });
}

const { entry, slug } = Astro.props;
const meta = findDoc(slug);
const { Content, headings } = await render(entry);

// In zh-CN reading order, skip docs that don't have a Chinese translation.
const zhDocs = docsOrder.filter((d) => d.locales.includes("zh-CN"));
const idx = zhDocs.findIndex((d) => d.slug === slug);
const prev = idx > 0 ? zhDocs[idx - 1] : undefined;
const next = idx >= 0 && idx < zhDocs.length - 1 ? zhDocs[idx + 1] : undefined;

const docLabel = meta?.label["zh-CN"] ?? slug;
const title = `${docLabel} · ThinkWatch 文档`;
const description = meta?.summary?.["zh-CN"];
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const jsonLd: Record<string, unknown>[] = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "首页", item: "https://thinkwat.ch/zh-CN/" },
      { "@type": "ListItem", position: 2, name: "文档", item: "https://thinkwat.ch/zh-CN/docs/" },
      { "@type": "ListItem", position: 3, name: docLabel, item: pageUrl },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    headline: docLabel,
    description,
    inLanguage: "zh-CN",
    url: pageUrl,
    author: { "@type": "Organization", name: "ThinkWatch Project", url: "https://github.com/ThinkWatchProject" },
    publisher: {
      "@type": "Organization",
      name: "ThinkWatch",
      logo: { "@type": "ImageObject", url: "https://thinkwat.ch/icon.svg" },
    },
  },
];
---

<DocsLayout
  title={title}
  description={description}
  current={slug}
  headings={headings}
  prev={prev}
  next={next}
  jsonLd={jsonLd}
>
  <Content />
</DocsLayout>
