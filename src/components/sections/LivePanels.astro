---
import DashboardMock from "../mocks/DashboardMock.tsx";
import LogExplorerMock from "../mocks/LogExplorerMock.tsx";
import ProviderHealthMock from "../mocks/ProviderHealthMock.tsx";
import RateLimitMock from "../mocks/RateLimitMock.tsx";
import { getLang, t } from "~/i18n";

const s = t(getLang(Astro)).live;
---

<section id="dashboard" class="py-28 border-t border-white/5 relative overflow-hidden">
  <div class="container-page relative z-10">
    <div class="max-w-3xl">
      <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-brand-1)] font-medium mb-4">
        {s.eyebrow}
      </div>
      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight">
        {s.title}<span class="text-gradient">{s.titleHighlight}</span>.
      </h2>
      <p class="mt-5 text-lg text-[var(--color-muted)] leading-relaxed">
        {s.sub}
      </p>
    </div>

    <div class="mt-14">
      <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)] mb-4">
        {s.overview}
      </div>
      <DashboardMock client:visible />
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-[1.4fr_1fr]">
      <div>
        <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)] mb-4">
          {s.logs}
        </div>
        <LogExplorerMock client:visible />
      </div>

      <div class="flex flex-col gap-6">
        <div>
          <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)] mb-4">
            {s.health}
          </div>
          <ProviderHealthMock client:visible />
        </div>
        <div>
          <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)] mb-4">
            {s.rate}
          </div>
          <RateLimitMock client:visible />
        </div>
      </div>
    </div>
  </div>
</section>
