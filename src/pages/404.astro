---
import Base from "~/layouts/Base.astro";
import SiteHeader from "~/components/SiteHeader.astro";
import SiteFooter from "~/components/SiteFooter.astro";
import { t } from "~/i18n";

const en = t("en").notFound;
const zh = t("zh-CN").notFound;
---

<Base title={en.title} description={en.description}>
  <SiteHeader />
  <main id="main" class="container-page py-32 text-center relative">
    <div class="absolute left-1/2 top-1/3 -translate-x-1/2 -translate-y-1/2 w-[34rem] h-[34rem] rounded-full bg-brand-gradient opacity-15 blur-[120px] pointer-events-none"></div>

    <div class="relative">
      <div class="text-[10rem] md:text-[14rem] font-semibold tracking-tighter leading-none">
        <span class="text-gradient">404</span>
      </div>
      <h1 class="mt-4 text-2xl md:text-3xl font-semibold tracking-tight">
        <span data-i18n="en">{en.headline}</span>
        <span data-i18n="zh-CN" hidden>{zh.headline}</span>
      </h1>
      <p class="mt-4 text-[var(--color-muted)] max-w-md mx-auto">
        <span data-i18n="en">{en.sub}</span>
        <span data-i18n="zh-CN" hidden>{zh.sub}</span>
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/"
          data-home-link
          class="px-5 py-3 rounded-lg bg-brand-gradient text-black font-medium hover:brightness-110 transition shadow-lg shadow-cyan-500/20"
        >
          <span data-i18n="en">{en.home}</span>
          <span data-i18n="zh-CN" hidden>{zh.home}</span>
        </a>
        <a
          href="/changelog"
          data-changelog-link
          class="px-5 py-3 rounded-lg border border-white/15 hover:border-white/30 hover:bg-white/5 transition font-medium"
        >
          <span data-i18n="en">{en.changelog}</span>
          <span data-i18n="zh-CN" hidden>{zh.changelog}</span>
        </a>
      </div>

      <pre class="mt-12 inline-block text-left font-mono text-xs text-[var(--color-dim)] bg-black/40 border border-white/10 rounded-lg px-4 py-3">
<span class="text-[var(--color-brand-1)]">$</span> curl -i https://thinkwat.ch{Astro.url.pathname}
HTTP/2 404
content-type: text/html
x-thinkwatch-audit: 01HQZ-NOT-FOUND</pre>
    </div>
  </main>
  <SiteFooter />
</Base>

<script is:inline define:vars={{ enTitle: en.title, zhTitle: zh.title }}>
  (function () {
    try {
      var stored = localStorage.getItem("tw-lang-pref");
      var pref = (stored === "en" || stored === "zh-CN")
        ? stored
        : ((navigator.language || "en").toLowerCase().indexOf("zh") === 0 ? "zh-CN" : "en");

      // Toggle visible spans
      document.querySelectorAll("[data-i18n]").forEach(function (el) {
        el.hidden = el.getAttribute("data-i18n") !== pref;
      });

      // Update <html lang> and <title>
      document.documentElement.lang = pref;
      document.title = pref === "zh-CN" ? zhTitle : enTitle;

      // Localize CTAs
      if (pref === "zh-CN") {
        var home = document.querySelector("[data-home-link]");
        var cl = document.querySelector("[data-changelog-link]");
        if (home) home.setAttribute("href", "/zh-CN/");
        if (cl) cl.setAttribute("href", "/zh-CN/changelog");
      }
    } catch (e) {}
  })();
</script>
