---
import CodeTabs from "./CodeTabs.tsx";

const steps = [
  {
    n: "1",
    title: "Start infrastructure",
    body: "Bring up PostgreSQL, Redis, and ClickHouse via Docker Compose.",
    cmd: "make infra",
  },
  {
    n: "2",
    title: "Start the gateway",
    body: "Both ports come up: 3000 (gateway) and 3001 (console API).",
    cmd: "cp .env.example .env && make dev-backend",
  },
  {
    n: "3",
    title: "Start the console UI",
    body: "Vite dev server on :5173 with hot reload.",
    cmd: "cd web && pnpm install && pnpm dev",
  },
  {
    n: "4",
    title: "Run the setup wizard",
    body: "Create the super_admin account and add your first provider.",
    cmd: "open http://localhost:5173/setup",
  },
];
---

<section id="quickstart" class="py-28 border-t border-white/5 relative">
  <div class="container-page relative z-10">
    <div class="max-w-3xl">
      <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-brand-1)] font-medium mb-4">
        Quick start
      </div>
      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight">
        Up and running in <span class="text-gradient">under a minute</span>.
      </h2>
      <p class="mt-5 text-lg text-[var(--color-muted)] leading-relaxed">
        Self-host with Docker Compose for a single-node deployment, or use the Helm chart for production Kubernetes. Either way, four commands and you have a working gateway.
      </p>
    </div>

    <div class="mt-14 grid lg:grid-cols-[1.1fr_1fr] gap-10 items-start">
      <!-- Steps -->
      <ol class="space-y-4">
        {steps.map((s) => (
          <li class="rounded-xl border border-white/10 bg-[var(--color-surface)]/60 p-5 flex gap-5">
            <div class="shrink-0 w-9 h-9 rounded-lg bg-brand-gradient text-black font-mono text-sm font-bold grid place-items-center">
              {s.n}
            </div>
            <div class="min-w-0 flex-1">
              <div class="font-semibold tracking-tight mb-1">{s.title}</div>
              <p class="text-sm text-[var(--color-muted)] mb-3">{s.body}</p>
              <code class="block font-mono text-xs text-[var(--color-brand-1)] bg-black/40 border border-white/10 rounded-md px-3 py-2 overflow-x-auto">
                $ {s.cmd}
              </code>
            </div>
          </li>
        ))}
      </ol>

      <!-- Code tabs -->
      <div class="lg:sticky lg:top-24">
        <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-muted)] mb-3">
          Then point your client at the gateway
        </div>
        <CodeTabs client:visible />
        <p class="mt-4 text-xs text-[var(--color-dim)]">
          Zero code changes required — just swap the base URL and use a virtual <code class="font-mono text-[var(--color-brand-1)]">tw-</code> key.
        </p>
      </div>
    </div>
  </div>
</section>
