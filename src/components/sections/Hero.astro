---
import { getCollection } from "astro:content";
import Terminal from "../ui/Terminal.tsx";
import MagneticButton from "../ui/MagneticButton.tsx";
import HeroVisual from "../hero/HeroVisual.tsx";
import { getLang, t } from "~/i18n";

const lang = getLang(Astro);
const s = t(lang).hero;
const common = t(lang).common;

// Latest changelog entry drives the version pill
const entries = await getCollection("changelog");
const latest = entries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];
const version = latest?.data.version ?? "0.1.0";
---

<section class="relative overflow-hidden pt-14 pb-20 sm:pt-20 sm:pb-28 lg:pt-24 lg:pb-32 lg:min-h-[88vh]">
  <HeroVisual client:load />

  <div class="container-page relative z-10 grid lg:grid-cols-[1.1fr_1fr] gap-10 lg:gap-12 items-center">
    <div>
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-white/[0.03] text-xs text-[var(--color-muted)] mb-5 sm:mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-1)] animate-pulse" aria-hidden="true"></span>
        {s.badge(version)}
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold tracking-tight leading-[1.08] sm:leading-[1.05]">
        {s.titleA}<br />
        {s.titleB}<span class="text-gradient">{s.titleHighlight}</span>
      </h1>

      <p class="mt-5 sm:mt-6 text-base sm:text-lg md:text-xl text-[var(--color-muted)] max-w-2xl leading-relaxed">
        {s.sub}
      </p>

      <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row sm:flex-wrap items-stretch sm:items-center gap-3 sm:gap-4">
        <MagneticButton
          client:visible
          href="#quickstart"
          className="text-center px-5 py-3 rounded-lg bg-brand-gradient text-black font-medium hover:brightness-110 shadow-lg shadow-cyan-500/20"
        >
          {s.ctaPrimary}
        </MagneticButton>
        <MagneticButton
          client:visible
          href="https://github.com/ThinkWatchProject/ThinkWatch"
          external
          className="text-center px-5 py-3 rounded-lg border border-white/15 hover:border-white/30 hover:bg-white/5 font-medium"
        >
          {common.githubLink}
        </MagneticButton>
      </div>

      <div class="mt-7 sm:mt-8 inline-flex items-center gap-3 rounded-md border border-white/10 bg-white/[0.02] px-3 py-2 text-xs">
        <span class="inline-flex items-center gap-1.5 font-mono text-[11px] font-medium text-[var(--color-accent)]">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] animate-pulse" aria-hidden="true"></span>
          {s.live.label}
        </span>
        <span class="w-px h-3 bg-white/10" aria-hidden="true"></span>
        <span class="font-mono tabular-nums text-white" data-live-reqs>1,284</span>
        <span class="font-mono text-[var(--color-dim)]">{s.live.reqPerSec}</span>
        <span class="text-[var(--color-dim)]" aria-hidden="true">/</span>
        <span class="font-mono tabular-nums text-white" data-live-tokens>42,730</span>
        <span class="font-mono text-[var(--color-dim)]">{s.live.tokensPerMin}</span>
      </div>
    </div>

    <div class="relative hidden sm:block">
      <Terminal client:visible />
      <div class="absolute -inset-6 -z-10 rounded-3xl bg-gradient-to-br from-cyan-500/20 via-violet-500/10 to-pink-500/20 blur-2xl"></div>
    </div>
  </div>

  <div class="container-page relative z-10 mt-14 sm:mt-20">
    <dl class="grid grid-cols-2 md:grid-cols-4 border-t border-l border-white/10">
      {s.stats.map((stat) => (
        <div class="border-r border-b border-white/10 px-5 py-5 sm:px-6 sm:py-6">
          <dt class="font-mono text-2xl sm:text-3xl text-white tracking-tight tabular-nums">
            {stat.value}
          </dt>
          <dd class="mt-1.5 text-[10px] sm:text-[11px] uppercase tracking-[0.14em] text-[var(--color-dim)]">
            {stat.label}
          </dd>
        </div>
      ))}
    </dl>
  </div>

  <div class="absolute inset-x-0 bottom-0 h-24 sm:h-32 bg-gradient-to-b from-transparent to-[var(--color-bg)] pointer-events-none"></div>
</section>

<script>
  // Subtle jitter so the LIVE pill feels alive without looking fake.
  const reqsEl = document.querySelector<HTMLSpanElement>("[data-live-reqs]");
  const tokensEl = document.querySelector<HTMLSpanElement>("[data-live-tokens]");
  if (reqsEl && tokensEl) {
    const fmt = (n: number) => n.toLocaleString("en-US");
    let reqs = 1284;
    let tokens = 42730;
    const tick = () => {
      reqs += Math.round((Math.random() - 0.45) * 32);
      tokens += Math.round((Math.random() - 0.4) * 900);
      reqs = Math.max(900, Math.min(1700, reqs));
      tokens = Math.max(30000, Math.min(55000, tokens));
      reqsEl.textContent = fmt(reqs);
      tokensEl.textContent = fmt(tokens);
    };
    setInterval(tick, 1800);
  }
</script>
