---
import { getLang, t } from "~/i18n";

const s = t(getLang(Astro)).license;

const ctaHrefs = [
  "#quickstart",
  "https://github.com/ThinkWatchProject/ThinkWatch/blob/main/LICENSING.md",
  "mailto:hello@thinkwat.ch?subject=ThinkWatch%20commercial%20license%20enquiry",
];

const tiers = s.tiers.map((tier, i) => ({
  ...tier,
  highlight: i === 1,
  cta: { label: tier.ctaLabel, href: ctaHrefs[i] },
}));
---

<section id="pricing" class="py-28 border-t border-white/5 relative">
  <div class="container-page relative z-10">
    <div class="max-w-3xl">
      <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-brand-1)] font-medium mb-4">
        {s.eyebrow}
      </div>
      <h2 class="text-4xl md:text-5xl font-semibold tracking-tight">
        {s.title}<span class="text-gradient">{s.titleHighlight}</span>.
      </h2>
      <p class="mt-5 text-lg text-[var(--color-muted)] leading-relaxed">
        {s.sub}
      </p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-3">
      {tiers.map((tier) => (
        <div
          class:list={[
            "relative rounded-2xl border p-7 flex flex-col",
            tier.highlight
              ? "border-transparent bg-[var(--color-surface)]/80 border-gradient"
              : "border-white/10 bg-[var(--color-surface)]/40",
          ]}
        >
          {tier.highlight && (
            <div class="absolute -top-3 left-7 px-2.5 py-0.5 rounded-full text-[10px] uppercase tracking-wider font-semibold bg-brand-gradient text-black">
              {s.mostTeams}
            </div>
          )}

          <div class="text-sm font-medium text-[var(--color-muted)]">{tier.name}</div>
          <div class="mt-3 flex items-baseline gap-2">
            <span class="text-4xl font-semibold tracking-tight">{tier.price}</span>
            <span class="text-xs text-[var(--color-dim)]">{tier.priceNote}</span>
          </div>
          <p class="mt-3 text-sm text-[var(--color-muted)]">{tier.audience}</p>

          <ul class="mt-6 space-y-2.5 text-sm flex-1">
            {tier.features.map((f) => (
              <li class="flex gap-2.5 items-start">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-[var(--color-brand-1)]" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8.5L6.5 12L13 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-[var(--color-text)]">{f}</span>
              </li>
            ))}
          </ul>

          <a
            href={tier.cta.href}
            class:list={[
              "mt-7 text-center text-sm font-medium px-4 py-2.5 rounded-lg transition",
              tier.highlight
                ? "bg-brand-gradient text-black hover:brightness-110"
                : "border border-white/15 hover:border-white/30 hover:bg-white/5",
            ]}
          >
            {tier.cta.label} →
          </a>
        </div>
      ))}
    </div>

    <p class="mt-10 text-center text-xs text-[var(--color-dim)]">
      {s.footnote[0]}<a href="https://github.com/ThinkWatchProject/ThinkWatch/blob/main/LICENSING.md" class="text-white underline underline-offset-4 hover:text-[var(--color-brand-1)]">{s.footnote[1]}</a>{s.footnote[2]}
    </p>
  </div>
</section>
